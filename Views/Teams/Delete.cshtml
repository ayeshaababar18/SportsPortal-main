@model SportsPortal.Models.Team

@{
    ViewData["Title"] = "Delete Team";
    Layout = "_LayoutAdmin";
}

<div class="container py-4">

    <h3>Are you sure you want to delete this?</h3>
    <div>
        <h4>Team</h4>
        <hr />
        <dl class="row">
            <dt class = "col-sm-2">
                @Html.DisplayNameFor(model => model.TeamName)
            </dt>
            <dd class = "col-sm-10">
                @Html.DisplayFor(model => model.TeamName)
            </dd>
            <dt class = "col-sm-2">
                @Html.DisplayNameFor(model => model.Sport)
            </dt>
            <dd class = "col-sm-10">
                @Html.DisplayFor(model => model.Sport.SportName)
            </dd>
            <dt class = "col-sm-2">
                @Html.DisplayNameFor(model => model.Department)
            </dt>
            <dd class = "col-sm-10">
                @Html.DisplayFor(model => model.Department.DeptName)
            </dd>
        </dl>
        
        <form asp-action="Delete">
            <input type="hidden" asp-for="TeamID" />
            <input type="submit" value="Delete" class="btn btn-danger" />
        </form>
    </div>
</div>
