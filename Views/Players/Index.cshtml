@model IEnumerable<SportsPortal.Models.Player>

@{
    ViewData["Title"] = "Players";
    Layout = User.IsInRole("Organizer") ? "_LayoutAdmin" : "_LayoutPublic";
}

<h1 class="text-primary mb-4">@(User.IsInRole("Organizer") ? "Manage Players" : "Players")</h1>

@if (User.IsInRole("Organizer"))
{
    <p>
        <a asp-action="Create" class="btn btn-primary">Create New Player</a>
    </p>
}

<form asp-controller="Players" asp-action="Index" method="get" class="mb-4 bg-light p-3 rounded shadow-sm">
    <div class="row g-3">
        <div class="col-md-3">
            <label class="form-label small fw-bold">Search</label>
            <input type="text" name="SearchString" value="@ViewData["CurrentFilter"]" class="form-control form-control-sm" placeholder="Name or Reg#..." />
        </div>
        <div class="col-md-2">
            <label class="form-label small fw-bold">Gender</label>
            <select name="gender" class="form-select form-select-sm" asp-items="Html.GetEnumSelectList<SportsPortal.Models.Gender>()">
                <option value="">All Genders</option>
            </select>
        </div>
        <div class="col-md-3">
            <label class="form-label small fw-bold">Department</label>
            <select name="deptId" class="form-select form-select-sm" asp-items="ViewBag.DeptID">
                <option value="">All Departments</option>
            </select>
        </div>
        <div class="col-md-2">
            <label class="form-label small fw-bold">Sport</label>
            <select name="sportId" class="form-select form-select-sm" asp-items="ViewBag.SportID">
                <option value="">All Sports</option>
            </select>
        </div>
        <div class="col-md-2 d-flex align-items-end gap-2">
            <button type="submit" class="btn btn-sm btn-primary flex-grow-1">Filter</button>
            <a asp-action="Index" class="btn btn-sm btn-outline-secondary">Clear</a>
        </div>
    </div>
</form>

<div class="table-responsive">
    <table class="table table-striped table-hover shadow-sm">
        <thead class="thead-dark">
            <tr>
                <th>
                    @Html.DisplayNameFor(model => model.FullName)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.RegNumber)
                </th>
                <th>
                    Gender
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.Department)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.Sport)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.IsCaptain)
                </th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
    @foreach (var item in Model) {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.FullName)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.RegNumber)
                </td>
                <td>
                    <span class="badge @(item.Gender == SportsPortal.Models.Gender.Male ? "bg-primary" : "bg-danger")">@item.Gender</span>
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Department.DeptName)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Sport.SportName)
                </td>
                <td>
                    <span class="badge @(item.IsCaptain ? "bg-success" : "bg-secondary")">@(item.IsCaptain ? "Yes" : "No")</span>
                </td>
                <td>
                    @if (User.IsInRole("Organizer"))
                    {
                        <a asp-action="Edit" asp-route-id="@item.PlayerID" class="btn btn-sm btn-primary">Edit</a>
                        <a asp-action="Delete" asp-route-id="@item.PlayerID" class="btn btn-sm btn-danger">Delete</a>
                    }
                    <a asp-action="Details" asp-route-id="@item.PlayerID" class="btn btn-sm btn-info">Details</a>
                </td>
            </tr>
    }
        </tbody>
    </table>
</div>
