@model SportsPortal.Models.Player

@{
    ViewData["Title"] = "Edit Player";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-0 text-center">
                    <h3 class="text-primary fw-bold mb-0">Edit Player</h3>
                    <p class="text-muted small">Update player details</p>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
                        <input type="hidden" asp-for="PlayerID" />
                        
                        <div class="mb-3">
                            <label asp-for="FullName" class="form-label text-muted small fw-bold">Full Name</label>
                            <input asp-for="FullName" class="form-control rounded-pill bg-light border-0 px-3" placeholder="Enter name" />
                            <span asp-validation-for="FullName" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="RegNumber" class="form-label text-muted small fw-bold">Registration Number</label>
                            <input asp-for="RegNumber" class="form-control rounded-pill bg-light border-0 px-3" placeholder="e.g. SP21-BSE-001" />
                            <span asp-validation-for="RegNumber" class="text-danger small"></span>
                        </div>

                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label asp-for="DeptID" class="form-label text-muted small fw-bold">Department</label>
                                <select asp-for="DeptID" class="form-select rounded-pill bg-light border-0 px-3" asp-items="ViewBag.DeptID"></select>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="SportID" class="form-label text-muted small fw-bold">Sport</label>
                                <select asp-for="SportID" class="form-select rounded-pill bg-light border-0 px-3" asp-items="ViewBag.SportID"></select>
                            </div>
                        </div>

                        <div class="mb-4">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" asp-for="IsCaptain" id="isCaptainCheck">
                                <label class="form-check-label" for="isCaptainCheck">Assign as Captain</label>
                            </div>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary rounded-pill py-2 fw-bold shadow-sm">Save Changes</button>
                            <a asp-action="Index" class="btn btn-light rounded-pill py-2 text-muted">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}