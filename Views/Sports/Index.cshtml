@model IEnumerable<SportsPortal.Models.Sport>

@{
    ViewData["Title"] = "Sports";
    Layout = User.IsInRole("Organizer") ? "_LayoutAdmin" : "_LayoutPublic";
}

<h1 class="text-primary mb-4">@(User.IsInRole("Organizer") ? "Manage Sports" : "Sports")</h1>

@if (User.IsInRole("Organizer"))
{
    <p>
        <a asp-action="Create" class="btn btn-primary">Create New Sport</a>
    </p>
}

<form asp-controller="Sports" asp-action="Index" method="get" class="mb-4">
    <div class="input-group">
        <input type="text" name="SearchString" value="@ViewData["CurrentFilter"]" class="form-control" placeholder="Search by sport name..." />
        <button type="submit" class="btn btn-outline-primary">Search</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
    </div>
</form>

<div class="table-responsive">
    <table class="table table-striped table-hover shadow-sm">
        <thead class="thead-dark">
            <tr>
                <th>
                    @Html.DisplayNameFor(model => model.SportName)
                </th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
    @foreach (var item in Model) {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.SportName)
                </td>
                <td>
                    @if (User.IsInRole("Organizer"))
                    {
                        <a asp-action="Edit" asp-route-id="@item.SportID" class="btn btn-sm btn-primary">Edit</a>
                        <a asp-action="Delete" asp-route-id="@item.SportID" class="btn btn-sm btn-danger">Delete</a>
                    }
                    <a asp-action="Details" asp-route-id="@item.SportID" class="btn btn-sm btn-info">Details</a>
                </td>
            </tr>
    }
        </tbody>
    </table>
</div>
