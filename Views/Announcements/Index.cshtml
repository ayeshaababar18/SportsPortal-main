@model IEnumerable<SportsPortal.Models.Announcement>

@{
    ViewData["Title"] = "Announcements";
    Layout = User.IsInRole("Organizer") ? "_LayoutAdmin" : "_LayoutPublic";
}

<h1 class="text-primary mb-4">@(User.IsInRole("Organizer") ? "Manage Announcements" : "Announcements")</h1>

@if (User.IsInRole("Organizer"))
{
    <p>
        <a asp-action="Create" class="btn btn-primary">Create New Announcement</a>
    </p>
}

<div class="table-responsive">
    <table class="table table-striped table-hover shadow-sm">
        <thead class="thead-dark">
            <tr>
                <th>
                    @Html.DisplayNameFor(model => model.Message)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.Priority)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.PostedDate)
                </th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
    @foreach (var item in Model) {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.Message)
                </td>
                <td>
                    <span class="badge @(item.Priority == "High" ? "bg-danger" : "bg-info")">@item.Priority</span>
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.PostedDate)
                </td>
                <td>
                    @if (User.IsInRole("Organizer"))
                    {
                        <a asp-action="Edit" asp-route-id="@item.AnnouncementID" class="btn btn-sm btn-primary">Edit</a>
                        <a asp-action="Delete" asp-route-id="@item.AnnouncementID" class="btn btn-sm btn-danger">Delete</a>
                    }
                    <a asp-action="Details" asp-route-id="@item.AnnouncementID" class="btn btn-sm btn-info">Details</a>
                </td>
            </tr>
    }
        </tbody>
    </table>
</div>
