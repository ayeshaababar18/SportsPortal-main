@model SportsPortal.Models.Match

@{
    ViewData["Title"] = "Delete Match";
}


<h3>Are you sure you want to delete this?</h3>
<div>
    <h4>Match</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Sport)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Sport.SportName)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.DepartmentA)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => Model.DepartmentA.DeptName ?? "N/A")
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.DepartmentB)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => Model.DepartmentB.DeptName ?? "N/A")
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.ScoreA)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.ScoreA)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.ScoreB)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.ScoreB)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Status)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Status)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.MatchDate)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.MatchDate)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Season)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Season.Year)
        </dd>
    </dl>
    
    <form asp-action="Delete">
        <input type="hidden" asp-for="MatchID" />
        <input type="submit" value="Delete" class="btn btn-danger" />
    </form>
</div>
