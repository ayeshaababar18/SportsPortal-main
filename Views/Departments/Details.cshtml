@model SportsPortal.Models.DepartmentDetailsViewModel

@{
    ViewData["Title"] = Model.Department.DeptName + " Profile";
}

<div class="container py-4">
    <div class="department-profile-header text-center mb-5 p-4 bg-primary rounded shadow-sm text-light">
        @if (!string.IsNullOrEmpty(Model.Department.LogoUrl))
        {
            <img src="@Model.Department.LogoUrl" alt="@Model.Department.DeptName Logo" class="img-fluid mb-3" style="max-height: 150px; object-fit: contain;">
        }
        <h1 class="display-4">@Model.Department.DeptName</h1>
        <p class="lead">Total Points: <strong class="text-accent">@Model.Department.TotalPoints</strong> | Rank: <strong class="text-accent">@Model.Rank</strong></p>
    </div>

    <div class="row">
        <div class="col-12">
            <h2 class="mb-3 text-primary">Match History</h2>
            @if (Model.Matches != null && Model.Matches.Any())
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover shadow-sm">
                        <thead class="table-cust-header">
                            <tr>
                                <th>Date</th>
                                <th>Sport</th>
                                <th>Team A</th>
                                <th>Team B</th>
                                <th>Score</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var match in Model.Matches)
                            {
                                <tr>
                                    <td>@match.MatchDate.ToShortDateString()</td>
                                    <td>@(match.Sport?.SportName ?? "N/A")</td>
                                    <td>@(match.DepartmentA?.DeptName ?? "TBD")</td>
                                    <td>@(match.DepartmentB?.DeptName ?? "TBD")</td>
                                    <td>@(match.ScoreA ?? "0") - @(match.ScoreB ?? "0")</td>
                                    <td>@match.Status</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-info" role="alert">
                    No match history available for this department.
                </div>
            }
        </div>
    </div>

    <div class="row mt-5">
        <div class="col-12">
            <h2 class="mb-3 text-primary">Squads</h2>
            @if (Model.PlayersBySport != null && Model.PlayersBySport.Any())
            {
                <div class="accordion" id="squadsAccordion">
                    @foreach (var sportGrouping in Model.PlayersBySport)
                    {
                        var sport = sportGrouping.Key;
                        var players = sportGrouping.Value;
                        var collapseId = $"collapseSport{sport.SportID}";
                        var headingId = $"headingSport{sport.SportID}";
                        var captain = players.FirstOrDefault(p => p.IsCaptain);

                        <div class="accordion-item">
                            <h2 class="accordion-header" id="@headingId">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#@collapseId" aria-expanded="false" aria-controls="@collapseId">
                                    @sport.SportName
                                </button>
                            </h2>
                            <div id="@collapseId" class="accordion-collapse collapse" aria-labelledby="@headingId" data-bs-parent="#squadsAccordion">
                                <div class="accordion-body">
                                    @if (captain != null)
                                    {
                                        <p><strong>Captain: @captain.FullName</strong></p>
                                    }
                                    else
                                    {
                                        <p>No captain assigned for this sport.</p>
                                    }
                                    <ul>
                                        @foreach (var player in players)
                                        {
                                            <li>@player.FullName</li>
                                        }
                                    </ul>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="alert alert-info" role="alert">
                    No squads found for this department.
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Optional: Any specific scripts for this page if needed
    </script>
}
