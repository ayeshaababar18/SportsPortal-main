@model SportsPortal.Models.Department

@{
    ViewData["Title"] = "Delete Department";
    Layout = "_LayoutAdmin";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-lg p-4 border-danger">
                <h3 class="text-center mb-4">Are you sure you want to delete this?</h3>
                <dl class="row">
                    <dt class="col-sm-4">
                        @Html.DisplayNameFor(model => model.DeptName)
                    </dt>
                    <dd class="col-sm-8">
                        @Html.DisplayFor(model => model.DeptName)
                    </dd>
                    <dt class="col-sm-4">
                        @Html.DisplayNameFor(model => model.TotalPoints)
                    </dt>
                    <dd class="col-sm-8">
                        @Html.DisplayFor(model => model.TotalPoints)
                    </dd>
                </dl>
                
                <form asp-action="Delete">
                    <input type="hidden" asp-for="DeptID" />
                    <div class="d-grid gap-2 mt-4">
                        <button type="submit" class="btn btn-danger btn-lg">Delete</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
