@{
    ViewData["Title"] = "Access Denied";
    Layout = "_LayoutAdmin";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 text-center">
            <h1 class="display-4 text-danger mb-4">Access Denied!</h1>
            <p class="lead">You do not have permission to view this resource.</p>
            <p class="mb-4">Please log in with an authorized account or contact your administrator if you believe this is an error.</p>
            <a asp-controller="Admin" asp-action="Login" class="btn btn-primary me-2">Go to Login</a>
            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">Back to Home</a>
        </div>
    </div>
</div>
