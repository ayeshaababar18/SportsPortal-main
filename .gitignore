## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## This .gitignore file was generated by visualstudio.com

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio 2015/2017/2019/2022 cache/options directory
.vs/
# Uncomment if you have tasks that create the TestResults folder
#TestResults/

# MSTest test Results
[Tt]est[Rr]esults/
[Bb]uild[Ll]og.*

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto generated files
mono_crash.*

# Windows image-cache files
Thumbs.db
ehthumbs.db

# Folder config file
Desktop.ini

# Recycle Bin used on secondary drives
$RECYCLE.BIN/

# NuGet Packages
*.nupkg
# The packages folder can be ignored because of Package Restore
**/[Pp]ackages/*
# except build/, which is used as an MSBuild target.
!**/[Pp]ackages/build/
# Uncomment if using NuGet repositories to store project specific packages (not recommended)
#!**/[Pp]ackages/
# NuGet Symbol Source Packages
*.snupkg

# BOWER/node_modules
node_modules/
bower_components/

# JetBrains Resharper temporary files
_ReSharper*/
*.[Rr]e[Ss][Hh]arper
*.DotSettings.user

# Visual Studio Code project settings
.vscode/

# Local History for Visual Studio Code
.history/

# Compiled files
*.dll
*.exe
*.pdb
*.exp
*.lib

# Output of dotnet publish
[Pp]ublish/

# Entity Framework-specific files
*.sqlite

# User-specific project settings
*.csproj.user
*.sqlproj.user
*.config.user

# Project-specific ignore
appsettings.Development.json
